# ==============================================
# Task & Calc - Variables de entorno (ejemplo)
# Copiar a .env y completar los valores reales.
# ==============================================

# Seguridad
SECRET_KEY=cambia-esta-clave-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Base de datos (Supabase / PostgreSQL)
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
# Si se deja vacía, se usa SQLite local (solo desarrollo).
DATABASE_URL=

# ---- FEATURE FLAGS (Variabilidad del software) ----
# Version 1 -> FEATURE_CALCULATOR=False (solo Tareas)
# Version 2 -> FEATURE_CALCULATOR=True  (Tareas + Calculadora)
FEATURE_CALCULATOR=False
